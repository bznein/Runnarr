# Comma-separated email=username mappings; no public signup is supported.
RUNNARR_OIDC_ALLOWED_EMAILS=
RUNNARR_ADMIN_USERNAME=admin
RUNNARR_ADMIN_PASSWORD=change-me
RUNNARR_SECRET_KEY=change-this-to-a-long-random-secret-with-at-least-32-bytes
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
