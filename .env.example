POSTGRES_USER=runnarr
POSTGRES_PASSWORD=runnarr
POSTGRES_DB=runnarr
DATABASE_URL=postgres://runnarr:runnarr@db:5432/runnarr?sslmode=disable

RUNNARR_HTTP_ADDR=127.0.0.1:8080
RUNNARR_FRONTEND_PORT=5173
RUNNARR_PORT=37617
RUNNARR_BASE_URL=http://localhost:37617
RUNNARR_PUBLIC_MODE=false
RUNNARR_LOCAL_AUTH_ENABLED=true
RUNNARR_TRUST_PROXY=false
RUNNARR_GOOGLE_CLIENT_ID=
RUNNARR_GOOGLE_CLIENT_SECRET=
